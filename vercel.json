{
  "rewrites": [
    { "source": "/api/login",        "destination": "/api/login.js" },
    { "source": "/api/dados",        "destination": "/api/dados.js" },
    { "source": "/api/salvar",       "destination": "/api/salvar.js" },
    { "source": "/api/migrar",       "destination": "/api/migrar.js" },
    { "source": "/api/trocar-senha", "destination": "/api/trocar-senha.js" }
  ],
  "headers": [
    {
      "source": "/:path*.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/:path*.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    }
  ]
}
